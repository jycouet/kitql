{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",
	"tabWidth": 1,
	"useTabs": true,
	"singleQuote": true,
	"trailingComma": "all",
	"semi": false,
	"arrowParens": "always",
	"printWidth": 100,
	"sortPackageJson": false,
	"sortImports": {
		"groups": [
			"builtin",
			{ "newlinesBetween": false },
			"external",
			"kitql-libs",
			"sveltekit",
			"aliases",
			["parent", "sibling", "index"],
			"unknown"
		],
		"customGroups": [
			{
				"groupName": "kitql-libs",
				"elementNamePattern": [
					"$houdini",
					"$houdini/**",
					"remult",
					"remult/**",
					"firstly",
					"firstly/**",
					"@kitql/**"
				]
			},
			{
				"groupName": "sveltekit",
				"elementNamePattern": ["$env", "$env/**", "$app", "$app/**"]
			},
			{
				"groupName": "aliases",
				"elementNamePattern": ["$server", "$server/**", "$modules", "$modules/**", "$*", "$*/**"]
			}
		],
		"newlinesBetween": true
	},
	"ignorePatterns": ["**/ROUTES.ts"]
}
